{
  "name": "greychrist",
  "private": true,
  "version": "0.3.13",
  "license": "AGPL-3.0",
  "main": ".vite/build/main.js",
  "scripts": {
    "prestart": "electron-rebuild -f -w better-sqlite3 2>/dev/null || true",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "dev": "vite --config vite.renderer.config.ts",
    "build": "tsc && vite build --config vite.renderer.config.ts",
    "preview": "vite preview",
    "check": "tsc --noEmit && tsc --noEmit -p tsconfig.electron.json",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3 && node -e \"const p=require('path').resolve('./node_modules/better-sqlite3/build/Release/better_sqlite3.node'); try{process.dlopen({exports:{}},p);process.stderr.write('rebuild:electron FAILED — binary is still Node ABI (NMV 115). Electron will crash on startup.\\n');process.exit(1)}catch(e){if(!e.message.includes('145')){process.stderr.write('rebuild:electron UNEXPECTED: '+e.message+'\\n');process.exit(1)}console.log('verified: better-sqlite3 at NMV 145 (Electron ABI)')}\"",
    "pretest": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "pretest:watch": "npm rebuild better-sqlite3",
    "test:watch": "vitest",
    "pretest:coverage": "npm rebuild better-sqlite3",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.112",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-select": "^2.1.3",
    "@radix-ui/react-tooltip": "^1.1.5",
    "@tailwindcss/cli": "^4.1.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.1.8",
    "@tanstack/react-virtual": "^3.13.10",
    "@types/diff": "^8.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@uiw/react-md-editor": "^4.0.7",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "diff": "^8.0.2",
    "framer-motion": "^12.0.0-alpha.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.3",
    "react-syntax-highlighter": "^15.6.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.8",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/sharp": "^0.32.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "electron": "^41.2.0",
    "sharp": "^0.34.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@tailwindcss/oxide"
  ],
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.25.6",
    "@rollup/rollup-linux-x64-gnu": "^4.45.1"
  }
}
